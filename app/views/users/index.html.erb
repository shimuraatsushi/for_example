<p style="color: green"><%= notice %></p>

<% content_for :title, "Users" %>

<h1>Users</h1>

<div id="users">
  <% @users.each do |user| %>
    <%= render user %>
    <p>
      <%= link_to "Show this user", user %>
    </p>
  <% end %>
</div>

<%= form_with model: @user do |f| %>
  <%= f.text_field :id %>
  <p><%= flash[:message] %></p>
<% end %>


<%= turbo_frame_tag "user_create" do %>
  <%= form_with model: @team, url: team_index_path, method: :post do |f| %>
    <%= f.text_field :name %>
    <%= f.text_field :user_id %>
    <%= f.submit %>
  <% end %>
<% end %>

<%= link_to "New user", new_user_path %>
